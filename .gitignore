node_modules/
dist/
dist-electron/
release/
*.log
.DS_Store
.env
.env.local
tsconfig*.tsbuildinfo

# Conchitect: never commit krpano license or user tour projects
assets/krpano/*.html
assets/krpano/krpanolicense.xml
sample-projects/

# Block .js files in src/ and electron/ — the project is 100% TypeScript.
# Stale compiled .js files shadow .ts(x) modules and break Vite resolution.
# (tsc -b has no outDir for these projects, so it emits .js next to the .ts
# source by default — these are always build output, never hand-written.)
src/**/*.js
electron/**/*.js
